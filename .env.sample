# =============================================================================
# n8n Configuration
# =============================================================================

# Public hostname — set this to your custom subdomain if using Cloudflare with a domain.
# Leave empty to use a random trycloudflare.com URL (no domain required).
N8N_HOST=

# Port n8n listens on locally (default: 5678).
N8N_PORT=5678

# Protocol exposed to clients. Use https when behind Cloudflare Tunnel.
N8N_PROTOCOL=https

# Set to true when running behind HTTPS (Cloudflare Tunnel). Set to false for local-only.
N8N_SECURE_COOKIE=true

# Full public URL used by n8n to generate webhook callback URLs.
# Must match N8N_HOST. Leave empty if N8N_HOST is empty.
# Example: https://n8n.example.com/
WEBHOOK_URL=

# Full public base URL for the n8n editor.
# Same as WEBHOOK_URL in most setups. Leave empty if N8N_HOST is empty.
N8N_EDITOR_BASE_URL=

# Your local timezone. See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE=UTC

# =============================================================================
# n8n Task Runners
# Runs JavaScript/Python code in isolated child processes (recommended).
# =============================================================================

N8N_RUNNERS_MODE=external
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_RUNNERS_BROKER_PORT=5679

# Shared secret between n8n and the runner container.
# Generate with: openssl rand -hex 32
N8N_RUNNERS_AUTH_TOKEN=

# =============================================================================
# Data Storage
# =============================================================================

# Local directory where n8n persists workflows, credentials, and settings.
# Use an absolute path or a path relative to this project root.
N8N_DATA_PATH=./n8n_data

# =============================================================================
# Cloudflare Tunnel (optional — only needed for external / HTTPS access)
# =============================================================================

# Name of your Cloudflare Tunnel (created with: cloudflared tunnel create <name>).
# Only used when CLOUDFLARE_HOSTNAME is set.
CLOUDFLARE_TUNNEL_NAME=ritexlabs-n8n

# Your public subdomain (e.g. n8n.example.com).
# Leave empty to get a free random *.trycloudflare.com URL (no login required).
CLOUDFLARE_HOSTNAME=
